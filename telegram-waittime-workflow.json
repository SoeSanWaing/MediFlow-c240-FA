    {
      "parameters": {
        "jsCode": "const messageText = $('Telegram Trigger').first().json.message.text;\nconst name = messageText.replace(/^\\/waittime\\s*/i, '').trim();\nif (!name) {\n  return [{ json: { patientName: '', error: true } }];\n}\nreturn [{ json: { patientName: name, error: false } }];"
      },
