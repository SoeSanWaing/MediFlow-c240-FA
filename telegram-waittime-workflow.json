    {
      "parameters": {
        "jsCode": "const patients = $input.all().map(item => item.json);\nconst searchName = $('Extract Patient Name').first().json.patientName.toLowerCase();\nconst now = new Date();\n\n// Find patient by name (partial match)\nconst patient = patients.find(p => \n  (p.patient_name || '').toLowerCase().includes(searchName)\n);\n\nif (!patient) {\n  return [{ json: { message: `❌ No patient found with name \"${$('Extract Patient Name').first().json.patientName}\".\\n\\nPlease check your spelling and try again.` } }];\n}\n\n// Calculate live countdown\nconst assignedTime = new Date(patient.assigned_date_time || patient.timestamp);\nconst elapsedMins = Math.floor((now.getTime() - assignedTime.getTime()) / 60000);\nconst waitMins = patient.estimated_wait_time_mins || 0;\nconst remaining = Math.max(0, waitMins - elapsedMins);\n\nconst severityEmoji = patient.severity === 'Critical' ? '🔴' : patient.severity === 'Urgent' ? '🟡' : '🟢';\n\nlet msg = `⏱️ *Wait Time Update*\\n\\n`;\nmsg += `👤 *${patient.patient_name}*\\n`;\nmsg += `${severityEmoji} Severity: ${patient.severity}\\n`;\nmsg += `📋 Status: ${patient.status}\\n\\n`;\n\nif (patient.status === 'Completed') {\n  msg += `✅ Your visit is completed.`;\n} else if (patient.status === 'In-Progress') {\n  msg += `🏥 You are currently in consultation.`;\n} else if (patient.status === 'Emergency') {\n  msg += `🚨 Emergency status - ambulance dispatched.`;\n} else if (remaining === 0) {\n  msg += `🔔 *You are due now!* Please proceed to the counter.`;\n} else {\n  msg += `⏳ Estimated wait: *${remaining} minutes*\\n`;\n  msg += `👨‍⚕️ Doctor: ${patient.doctor_assigned || 'To be assigned'}`;\n}\n\nmsg += `\\n\\n🕐 _Updated: ${now.toLocaleTimeString('en-SG', { hour: '2-digit', minute: '2-digit' })}_`;\n\nreturn [{ json: { message: msg } }];"
      },
      "type": "n8n-nodes-base.code",
