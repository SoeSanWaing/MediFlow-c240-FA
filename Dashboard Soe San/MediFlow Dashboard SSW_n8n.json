      "parameters": {
        "jsCode": "function normStatus(s) {\n  return String(s || '').trim().toLowerCase().replace(/[\\s_-]+/g, '');\n}\n\nconst body = $('UpdateStatus').first().json.body;\nconst existing = $input.first().json; // fetched current row, may be empty object if not found\n\nconst requestedStatus = body.status;\nconst requestedNorm = normStatus(requestedStatus);\nconst existingNorm = normStatus(existing.status);\n\nconst isInvalidNoShow = requestedNorm === 'noshow' && existingNorm !== 'waiting';\n\n// If invalid, keep the patient's current status instead of applying the change.\nconst newStatus = isInvalidNoShow ? existing.status : requestedStatus;\nconst isEmergency = normStatus(newStatus) === 'emergency';\n\nreturn [{\n  json: {\n    patient_id: body.patient_id,\n    status: newStatus,\n    estimated_wait_time_mins: isEmergency ? 0 : (existing.estimated_wait_time_mins ?? 0),\n    estimated_consult_time_mins: isEmergency ? 0 : (existing.estimated_consult_time_mins ?? 0)\n  }\n}];"
      },
