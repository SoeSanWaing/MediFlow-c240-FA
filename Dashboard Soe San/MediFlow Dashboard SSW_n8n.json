    {
      "parameters": {
        "jsCode": "// ---- helpers ----\n// \"today\" is computed explicitly in Asia/Singapore time (matches the fix\n// applied to Filtering Completed status) rather than relying on n8n's\n// $today, which depends on the instance's configured workflow timezone.\nfunction todayInSingapore() {\n  return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Singapore' }).format(new Date());\n}\n\nfunction getDatePart(ts) {\n  if (!ts) return null;\n  const s = String(ts).trim();\n  const m = s.match(/^(\\d{4}-\\d{2}-\\d{2})/);\n  if (m) return m[1];\n  const d = new Date(s);\n  if (isNaN(d.getTime())) return null;\n  return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Singapore' }).format(d);\n}\n\nfunction normStatus(s) {\n  return String(s || '').trim().toLowerCase().replace(/[\\s_-]+/g, '');\n}\n\nconst todayStr = todayInSingapore();\nconst severityScores = { \"Critical\": 1, \"Urgent\": 2, \"Standard\": 3 };\n\nconst allPatients = $input.all().map(item => item.json);\n\n// Only consider TODAY's session queue.\nconst todaysPatients = allPatients.filter(p => getDatePart(p.timestamp) === todayStr);\n\nconst waiting = todaysPatients.filter(p => normStatus(p.status) === 'waiting');\nconst inProgress = todaysPatients.filter(p => normStatus(p.status) === 'inprogress');\n\n// Doctor-based fix: wait time is now calculated PER DOCTOR, not as one\n// shared clinic-wide queue. Doctors work in parallel, so a patient's real\n// wait depends on who's ahead of them for THEIR specific doctor, not on\n// every Critical/Urgent patient across the whole clinic.\nconst UNASSIGNED = 'Unassigned';\nfunction doctorKey(p) {\n  const name = String(p.doctor_assigned || '').trim();\n  return name || UNASSIGNED;\n}\n\n// Group In-Progress patients by doctor, so each doctor's own head-start\n// (50% of their current patient's consult time) only affects that doctor's\n// own queue, not everyone else's.\nconst inProgressByDoctor = {};\nfor (const p of inProgress) {\n  const key = doctorKey(p);\n  inProgressByDoctor[key] = (inProgressByDoctor[key] || 0) + (Number(p.estimated_consult_time_mins || 0) * 0.5);\n}\n\n// Group Waiting patients by doctor.\nconst waitingByDoctor = {};\nfor (const p of waiting) {\n  const key = doctorKey(p);\n  if (!waitingByDoctor[key]) waitingByDoctor[key] = [];\n  waitingByDoctor[key].push(p);\n}\n\nconst updatedWaiting = [];\n\nfor (const [doctor, patients] of Object.entries(waitingByDoctor)) {\n  // Same severity -> timestamp sort as before, but scoped to this doctor's own queue.\n  patients.sort((a, b) => {\n    const sa = severityScores[a.severity] || 3;\n    const sb = severityScores[b.severity] || 3;\n    if (sa !== sb) return sa - sb;\n    return new Date(a.timestamp) - new Date(b.timestamp);\n  });\n\n  let cumulativeWait = inProgressByDoctor[doctor] || 0;\n  for (const patient of patients) {\n    patient.estimated_wait_time_mins = Math.round(cumulativeWait);\n    cumulativeWait += Number(patient.estimated_consult_time_mins || 0);\n    updatedWaiting.push({ json: patient });\n  }\n}\n\n// Only Waiting patients need their wait time written back; In-Progress\n// patients are left untouched since they're already being served.\nreturn updatedWaiting;"
      },
