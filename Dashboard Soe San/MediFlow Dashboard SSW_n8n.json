    {
      "parameters": {
        "jsCode": "const TERMINAL_STATUSES = new Set(['completed', 'done', 'discharged', 'cancelled', 'canceled', 'noshow', 'no-show']);\nfunction normStatus(s) {\n  return String(s || '').trim().toLowerCase().replace(/[\\s_-]+/g, '');\n}\n\nconst patientId = $('UpdateStatus').first().json.body.patient_id;\nconst allPatients = $('Get row(s) in sheet4').all().map(i => i.json);\nconst patient = allPatients.find(p => String(p.patient_id) === String(patientId));\n\nif (!patient || !patient.doctor_assigned) return [];\n\nconst statusNorm = normStatus(patient.status);\nlet newAvailability = null;\n\nif (statusNorm === 'inprogress') {\n  newAvailability = 'Busy';\n} else if (TERMINAL_STATUSES.has(statusNorm) || statusNorm === 'emergency') {\n  newAvailability = 'Available';\n} else {\n  return [];\n}\n\nconst doctors = $input.all().map(i => i.json);\nconst doctorRow = doctors.find(d => d.doctor_name === patient.doctor_assigned);\nif (!doctorRow) return [];\nif (doctorRow.availability_status === newAvailability) return [];\n\nreturn [{\n  json: {\n    doctor_name: patient.doctor_assigned,\n    availability_status: newAvailability\n  }\n}];"
      },
