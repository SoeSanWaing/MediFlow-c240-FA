    {
      "parameters": {
        "jsCode": "const TERMINAL_STATUSES = new Set(['completed', 'done', 'discharged', 'cancelled', 'canceled']);\n\nfunction todayInSingapore() {\n  return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Singapore' }).format(new Date());\n}\n\nfunction getDatePart(ts) {\n  if (!ts) return null;\n  const s = String(ts).trim();\n  const m = s.match(/^(\\d{4}-\\d{2}-\\d{2})/);\n  if (m) return m[1];\n  const d = new Date(s);\n  if (isNaN(d.getTime())) return null;\n  return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Singapore' }).format(d);\n}\n\nconst rawDateParam = $('GetData').first().json.query?.date;\nconst normalizedDateParam = getDatePart(rawDateParam);\nconst isHistoricalSearch = Boolean(normalizedDateParam) && normalizedDateParam !== todayInSingapore();\nconst targetDateStr = isHistoricalSearch ? normalizedDateParam : todayInSingapore();\n\nconst rawData = $input.all().map(item => item.json);\nconst groupedData = {};\n\nfor (const patient of rawData) {\n  if (getDatePart(patient.timestamp) !== targetDateStr) continue;\n\n  if (!isHistoricalSearch) {\n    const status = String(patient.status || '').trim().toLowerCase();\n    if (TERMINAL_STATUSES.has(status)) continue;\n  }\n\n  const category = patient.category || 'Uncategorized';\n  if (!groupedData[category]) groupedData[category] = [];\n  groupedData[category].push(patient);\n}\n\nreturn [{ json: groupedData }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
